<h1>Edit: <em><%= ERB::Util.html_escape(@info['title'].to_s) %></em></h1>

<form action="/books/<%= @id %>" method="post">
  <input type="hidden" name="_method" value="PATCH">

  <label for="title">Title <span style="color:#c00;">*</span></label>
  <input type="text" id="title" name="title" required
         value="<%= ERB::Util.html_escape(@info['title'].to_s) %>">

  <label for="authors">Authors <small>(comma-separated)</small></label>
  <input type="text" id="authors" name="authors"
         value="<%= ERB::Util.html_escape((@info['authors'] || []).join(', ')) %>">

  <label for="publisher">Publisher</label>
  <input type="text" id="publisher" name="publisher"
         value="<%= ERB::Util.html_escape(@info['publisher'].to_s) %>">

  <label for="isbn">ISBN</label>
  <input type="text" id="isbn" name="isbn"
         value="<%= ERB::Util.html_escape((@info['ISBN'] || @info['isbn']).to_s) %>">

  <label for="notes">Notes</label>
  <textarea id="notes" name="notes" rows="4"><%= ERB::Util.html_escape(@info['notes'].to_s) %></textarea>

  <div style="margin-top:1.2rem; display:flex; gap:0.75rem; align-items:center;">
    <button type="submit">Save Changes</button>
    <a href="/" class="btn btn-secondary">Cancel</a>
  </div>
</form>

<hr>

<h2>Cover Image</h2>

<% if @has_cover %>
  <img src="/covers/<%= @id %>" alt="Current cover"
       style="height:160px; border:1px solid #ddd; border-radius:3px;
              display:block; margin-bottom:1rem;">
<% else %>
  <p style="color:#999; margin-bottom:1rem;">No cover image yet.</p>
<% end %>

<h3>Upload a file</h3>
<form action="/books/<%= @id %>/cover" method="post" enctype="multipart/form-data"
      style="display:flex; gap:0.75rem; align-items:flex-end; flex-wrap:wrap;">
  <div style="flex:1; min-width:200px;">
    <label for="cover_file" style="margin-top:0;">Image file</label>
    <input type="file" id="cover_file" name="cover_file" accept="image/*">
  </div>
  <button type="submit">Upload</button>
</form>

<h3>Fetch from URL</h3>
<form action="/books/<%= @id %>/cover" method="post"
      style="display:flex; gap:0.75rem; align-items:flex-end; flex-wrap:wrap;">
  <div style="flex:1; min-width:200px;">
    <label for="cover_url" style="margin-top:0;">Image URL</label>
    <input type="url" id="cover_url" name="cover_url" placeholder="https://…">
  </div>
  <button type="submit">Fetch Cover</button>
</form>

<hr>

<h2 style="color:#8b2020;">Danger Zone</h2>

<h3>Make this an edition of&hellip;</h3>
<p style="color:#666; font-size:0.9rem; margin-top:-0.5rem;">
  Moves this folder inside another book folder. The static viewer will treat it as one of that book's editions.
</p>
<form action="/books/<%= @id %>/move" method="post"
      style="display:flex; gap:0.75rem; align-items:flex-end; flex-wrap:wrap;"
      onsubmit="return confirm('Move this folder? This cannot be undone from here.')">
  <div style="flex:1; min-width:200px;">
    <label for="parent_id" style="margin-top:0;">Parent book</label>
    <select id="parent_id" name="parent_id" style="width:100%; padding:0.45rem 0.6rem; border:1px solid #ccc; border-radius:4px; font-size:0.95rem;">
      <option value="">— select —</option>
      <% @shelf_folders.each do |f| %>
        <option value="<%= encode_id(f) %>"><%= ERB::Util.html_escape(File.basename(f)) %></option>
      <% end %>
    </select>
  </div>
  <button type="submit" style="background:#8b2020;">Move</button>
</form>

<h3>Delete this book</h3>
<p style="color:#666; font-size:0.9rem; margin-top:-0.5rem;">
  If the folder contains only metadata (no book files) it will be deleted entirely.
  Otherwise only the metadata is removed and the folder is kept.
</p>
<form action="/books/<%= @id %>" method="post"
      onsubmit="return confirm('Delete \u201c<%= ERB::Util.html_escape(@info['title'].to_s) %>\u201d? This cannot be undone.')">
  <input type="hidden" name="_method" value="DELETE">
  <button type="submit" style="background:#8b2020;">Delete</button>
</form>
