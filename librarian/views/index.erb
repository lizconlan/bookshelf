<h1>Your Library <small style="font-size:0.6em; color:#888;">(<%= @books.count %> books)</small></h1>

<% unless @incompletes.empty? %>
  <div class="flash-error">
    <strong><%= @incompletes.count %> folder<%= @incompletes.count == 1 ? '' : 's' %> without metadata:</strong>
    <ul style="margin:0.4rem 0 0; padding-left:1.2rem;">
      <% @incompletes.each do |f| %>
        <li>
          <%= ERB::Util.html_escape(File.basename(f)) %>
          &ndash; <a href="/books/<%= encode_id(f) %>/init" style="color:#721c24;">add metadata</a>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>

<input type="search" id="book-search" placeholder="Filter by title, author, or publisher…"
       oninput="filterBooks(this.value)" style="margin-bottom:1rem;">

<table id="books-table">
  <thead>
    <tr>
      <th style="width:44px">Cover</th>
      <th>Title</th>
      <th>Authors</th>
      <th>Publisher</th>
      <th>ISBN</th>
      <th style="width:60px"></th>
    </tr>
  </thead>
  <tbody>
    <% @books.each do |book| %>
      <% folder = book_folder(book) %>
      <% id = encode_id(folder) %>
      <tr data-search="<%= ERB::Util.html_escape([book.title, book.authors.join(' '), book.publisher].join(' ').downcase) %>">
        <td>
          <% if cover_exists?(folder) %>
            <img src="/covers/<%= id %>" class="cover-thumb" alt="">
          <% else %>
            <span class="tag tag-missing" title="No cover image">&#8212;</span>
          <% end %>
        </td>
        <td><strong><%= ERB::Util.html_escape(book.title.to_s) %></strong></td>
        <td><%= ERB::Util.html_escape(book.authors.join(', ')) %></td>
        <td>
          <% if book.publisher.to_s.empty? %>
            <em style="color:#999">self-published</em>
          <% else %>
            <%= ERB::Util.html_escape(book.publisher) %>
          <% end %>
        </td>
        <td style="font-size:0.85rem; color:#666"><%= ERB::Util.html_escape(book.isbn.to_s) %></td>
        <td>
          <% if book.editions? %>
            <a href="/books/<%= id %>/editions" class="btn btn-secondary btn-sm">Editions</a>
          <% else %>
            <a href="/books/<%= id %>/edit" class="btn btn-secondary btn-sm">Edit</a>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<script>
function filterBooks(query) {
  const q = query.toLowerCase();
  document.querySelectorAll('#books-table tbody tr').forEach(row => {
    row.style.display = row.dataset.search.includes(q) ? '' : 'none';
  });
}
</script>
